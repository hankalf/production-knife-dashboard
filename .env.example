# Copy to .env and adjust for your environment.

# PostgreSQL connection string.
# Local dev: use the bundled docker-compose Postgres (see README), or your own.
# On Railway/Render: the database provides this automatically.
DATABASE_URL="postgresql://knife:knife@localhost:5432/knifedb?schema=public"

# Timezone used for due-date math ("end of today" for FC knives, "end of
# Friday" for NFC). Use an IANA name (e.g. America/Chicago, America/New_York,
# Europe/London). If unset, the server's local time is used — on most cloud
# hosts that is UTC, which is usually NOT what you want for shift cut-offs.
TZ="America/Chicago"
